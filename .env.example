# ---- Supabase (required) ----
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=<service_role_or_anon_key>

# ---- Apify (required for collectors) ----
APIFY_TOKEN=<apify_api_token>

# ---- Apify Actor IDs (optional — defaults set in config.py) ----
# ACTOR_CATEGORY=BG3WDrGdteHgZgbPK       # junglee/Amazon-crawler
# ACTOR_REVIEWS=gFtgG31RZJYlphznm        # web_wanderer/amazon-reviews-extractor

# ---- OpenClaw Gateway (optional) ----
# OpenClaw is launched separately (see README). Gateway manages Telegram pairing and its own LLM key.
# OPENAI_API_KEY=<used_by_openclaw_gateway>

# ---- Debug ----
# DEBUG=1
